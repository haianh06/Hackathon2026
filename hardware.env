# ═══════════════════════════════════════════════════════════════
# Motor PWM Configuration — Dual MG996R 360° Continuous-Rotation Servo
# Hai servo đã được cân bằng, dead band center = 1500µs, tốc độ tương đương
# Chỉnh các giá trị dưới đây để tinh chỉnh mà không cần rebuild Docker
# ═══════════════════════════════════════════════════════════════

# --- GPIO Pins (đánh số BCM) ---
# Chân GPIO điều khiển servo trái và phải
MOTOR_LEFT_PIN=12
MOTOR_RIGHT_PIN=13

# --- Hardware PWM Channel Mapping (Pi5 sysfs) ---
# dtoverlay=pwm-2chan,pin=12,func=4,pin2=13,func2=4
# GPIO 12 → pwmchip2, channel 0
# GPIO 13 → pwmchip2, channel 2
MOTOR_LEFT_PWM_CHIP=2
MOTOR_LEFT_PWM_CHANNEL=0
MOTOR_RIGHT_PWM_CHIP=2
MOTOR_RIGHT_PWM_CHANNEL=2

# --- PWM Frequency (Hz) ---
# Tần số PWM cho servo (50Hz = chu kỳ 20ms, chuẩn cho servo RC)
MOTOR_PWM_FREQ=50

# --- Neutral (dead band center) pulse width µs ---
# Điểm trung tâm dead band — servo KHÔNG quay tại giá trị này
# Cả 2 servo đã cân bằng tại 1500µs
MOTOR_LEFT_NEUTRAL=1500
MOTOR_RIGHT_NEUTRAL=1500

# --- Stop Point Calibration µs (Điểm dừng tuyệt đối) ---
# Do sai số sản xuất, MG996R có thể không dừng chính xác tại 1500µs
# (duty cycle 7.5%). Có thể cần 7.3% (~1460µs) hoặc 7.7% (~1540µs).
# Chỉnh ±20µs nếu servo vẫn rung/quay nhẹ khi dừng.
# Cách tìm: đặt neutral, nếu servo vẫn quay nhẹ → tăng/giảm giá trị này
MOTOR_LEFT_STOP_POINT=1500
MOTOR_RIGHT_STOP_POINT=1500

# --- Drive speed offset from neutral µs (tốc độ chạy thẳng) ---
# Forward = neutral + offset, Backward = neutral - offset
# Hai servo cân bằng → cùng offset. Tăng = nhanh hơn, giảm = chậm hơn
# Phạm vi an toàn: 100–300µs
MOTOR_LEFT_DRIVE_OFFSET=200
MOTOR_RIGHT_DRIVE_OFFSET=200

# --- Turn speed offset from neutral µs (tốc độ xoay tại chỗ) ---
# Xe xoay pivot: 1 bánh tiến, 1 bánh lùi
# Có thể khác drive offset để xoay chậm/nhanh hơn
MOTOR_LEFT_TURN_OFFSET=200
MOTOR_RIGHT_TURN_OFFSET=200

# --- Left motor mirror-mounted (gắn ngược) ---
# Đặt 1 nếu servo trái gắn ngược chiều (cần đảo xung trong calibration UI)
MOTOR_LEFT_MIRROR=0

# --- Drift bias (bù trôi khi chạy thẳng) ---
# Dương = bù sang phải, âm = bù sang trái
# Hai servo đã cân bằng → đặt 0. Chỉnh nếu xe bị lệch khi chạy thẳng
# Phạm vi: -0.15 … +0.15. Bắt đầu nhỏ, tăng dần nếu vẫn lệch
MOTOR_DRIFT_BIAS=0.0

# --- PWM Ramp (tăng tốc từ từ — chống sụt áp & nhiễu xung PWM) ---
# Khi xe bắt đầu di chuyển, xung PWM sẽ được tăng từ từ (ramp)
# thay vì đẩy xung 1 phát → tránh sụt áp, nhiễu, giật servo
# RAMP_STEP_US: mỗi bước tăng bao nhiêu µs (nhỏ = mượt, chậm hơn)
# RAMP_STEP_MS: thời gian chờ giữa mỗi bước (ms)
# Ví dụ: offset 200µs ÷ step 10µs = 20 bước × 10ms = ramp ~200ms
MOTOR_RAMP_STEP_US=10
MOTOR_RAMP_STEP_MS=10
