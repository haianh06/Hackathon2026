# ═══════════════════════════════════════════════════════════════
# Motor PWM Configuration — Dual MG996R 360° Continuous-Rotation Servo
# Hai servo đã được cân bằng, dead band center = 1500µs, tốc độ tương đương
# Chỉnh các giá trị dưới đây để tinh chỉnh mà không cần rebuild Docker
# ═══════════════════════════════════════════════════════════════

# --- GPIO Pins (đánh số BCM) ---
# Chân GPIO điều khiển servo trái và phải
MOTOR_LEFT_PIN=12
MOTOR_RIGHT_PIN=13

# --- Hardware PWM Channel Mapping (Pi5 sysfs) ---
# dtoverlay=pwm-2chan,pin=12,func=4,pin2=13,func2=4
# GPIO 12 → pwmchip0, channel 0
# GPIO 13 → pwmchip0, channel 1
MOTOR_LEFT_PWM_CHIP=0
MOTOR_LEFT_PWM_CHANNEL=0
MOTOR_RIGHT_PWM_CHIP=0
MOTOR_RIGHT_PWM_CHANNEL=1

# --- PWM Frequency (Hz) ---
# Tần số PWM cho servo (50Hz = chu kỳ 20ms, chuẩn cho servo RC)
MOTOR_PWM_FREQ=50

# --- Neutral (dead band center) pulse width µs ---
# Điểm trung tâm dead band — servo KHÔNG quay tại giá trị này
# Cả 2 servo đã cân bằng tại 1500µs
MOTOR_LEFT_NEUTRAL=1500
MOTOR_RIGHT_NEUTRAL=1500

# --- Stop Point Calibration µs (Điểm dừng tuyệt đối) ---
# Do sai số sản xuất, MG996R có thể không dừng chính xác tại 1500µs
# (duty cycle 7.5%). Có thể cần 7.3% (~1460µs) hoặc 7.7% (~1540µs).
# Chỉnh ±20µs nếu servo vẫn rung/quay nhẹ khi dừng.
# Cách tìm: đặt neutral, nếu servo vẫn quay nhẹ → tăng/giảm giá trị này
MOTOR_LEFT_STOP_POINT=1500
MOTOR_RIGHT_STOP_POINT=1500

# --- Drive speed offset from neutral µs (tốc độ chạy thẳng) ---
# Mirror-mounted servos: chiều quay ngược nhau
#   Left:  Forward = neutral - offset (dưới neutral), Backward = neutral + offset
#   Right: Forward = neutral + offset (trên neutral), Backward = neutral - offset
# Hai servo ĐÃ cân bằng tốc độ thực tế:
#   GPIO12 (trái) 1700µs = GPIO13 (phải) 2000µs  → cùng tốc độ vật lý
# Phạm vi an toàn: 100–500µs
MOTOR_LEFT_DRIVE_OFFSET=200
MOTOR_RIGHT_DRIVE_OFFSET=200

# --- Turn speed offset from neutral µs (tốc độ xoay tại chỗ) ---
# Xe xoay pivot: 1 bánh tiến, 1 bánh lùi
# Có thể khác drive offset để xoay chậm/nhanh hơn
MOTOR_LEFT_TURN_OFFSET=200
MOTOR_RIGHT_TURN_OFFSET=200

# --- Left motor mirror-mounted (gắn ngược) ---
# Đặt 1 nếu servo trái gắn ngược chiều (cần đảo xung trong calibration UI)
MOTOR_LEFT_MIRROR=0

# --- Drift bias (bù trôi khi chạy thẳng) ---
# Dương = bù sang phải, âm = bù sang trái
# Hai servo đã cân bằng → đặt 0. Chỉnh nếu xe bị lệch khi chạy thẳng
# Phạm vi: -0.15 … +0.15. Bắt đầu nhỏ, tăng dần nếu vẫn lệch
MOTOR_DRIFT_BIAS=0.0

# --- Steering inversion ---
# Đặt 1 nếu xe lái ngược chiều mong muốn khi bám làn
# (CTE báo rẽ phải nhưng servo sai bên quay)
MOTOR_STEER_INVERT=1

# --- PWM Ramp (tăng tốc từ từ — chống sụt áp & nhiễu xung PWM) ---
# Khi xe bắt đầu di chuyển, xung PWM sẽ được tăng từ từ (ramp)
# thay vì đẩy xung 1 phát → tránh sụt áp, nhiễu, giật servo
# RAMP_STEP_US: mỗi bước tăng bao nhiêu µs (nhỏ = mượt, chậm hơn)
# RAMP_STEP_MS: thời gian chờ giữa mỗi bước (ms)
# Ví dụ: offset 200µs ÷ step 10µs = 20 bước × 10ms = ramp ~200ms
MOTOR_RAMP_STEP_US=10
MOTOR_RAMP_STEP_MS=10

# --- Deadband (vùng chết — chống rung/kêu servo gần neutral) ---
# Nếu |pulse - neutral| < DEADBAND_US → tắt PWM hẳn (không gửi xung)
# Servo MG996R 360° thường có deadband ~10-20µs quanh neutral
# Đặt 15µs để tránh servo kêu xẹt xẹt / quay nhẹ khi gần neutral
MOTOR_DEADBAND_US=15

# --- EMA Filter (lọc nhiễu xung PWM — chống spike điện áp) ---
# Exponential Moving Average: làm mượt xung trước khi gửi cho servo
# Alpha thấp (0.2) = lọc mạnh, phản hồi chậm
# Alpha cao (0.5) = lọc nhẹ, phản hồi nhanh
# 0.3 = cân bằng tốt cho servo MG996R trên Pi5
MOTOR_EMA_ALPHA=0.3

# --- Force-stop (dừng cưỡng bức — chống servo chạy mất kiểm soát) ---
# Khi gọi stop(), sẽ gọi .stop() trên PWM N lần, cách nhau M ms
# Đề phòng lệnh stop bị lỗi hoặc servo latch xung sai
MOTOR_STOP_RETRIES=3
MOTOR_STOP_RETRY_MS=20

# ═══════════════════════════════════════════════════════════════
# Navigation Calibration — Ánh xạ toạ độ map ↔ chuyển động thực tế
# ═══════════════════════════════════════════════════════════════

# --- Thời gian lái (giây) cho mỗi đơn vị toạ độ trên map ảo ---
# ĐÂY LÀ THAM SỐ QUAN TRỌNG NHẤT: quy định xe chạy bao lâu giữa 2 điểm.
#
# Công thức: drive_time = khoảng_cách_Euclidean × NAV_DRIVE_TIME_PER_COORD
# Ví dụ: 2 điểm cách nhau 400 coord → drive_time = 400 × 0.002 = 0.8 giây
#
# Nếu xe chạy CHƯA HẾT quãng đường thực (dừng sớm) → TĂNG giá trị này
# Nếu xe chạy QUÁ xa (vượt điểm đến) → GIẢM giá trị này
# Tinh chỉnh: thay đổi 0.001 mỗi lần, quan sát, lặp lại
NAV_DRIVE_TIME_PER_COORD=0.01

# --- Thời gian xoay 90° tại chỗ (giây) ---
# Servo pivot: 1 bánh tiến + 1 bánh lùi để xoay tại chỗ
# Nếu xe xoay CHƯA ĐỦ 90° → tăng. Nếu xoay QUÁ → giảm
NAV_TURN_90_TIME=1.60

# --- Hệ số bù xoay (>1 = xoay thêm, <1 = xoay bớt) ---
# Thực tế servo 2 bên có tốc độ khác nhau → xoay bị thiếu/thừa
# Tổng thời gian xoay = NAV_TURN_90_TIME × NAV_TURN_CORRECTION
NAV_TURN_CORRECTION=1.05

# --- Thời gian xung bù drift sau mỗi lần xoay (giây) ---
# Sau khi xoay 90°, servo có quán tính → bù 1 xung ngắn ngược chiều
NAV_DRIFT_CORRECTION_TIME=0.10

# --- Tần suất báo cáo vị trí trung gian (giây) ---
# Frontend nhận vị trí interpolated để animate xe trên map
NAV_POSITION_REPORT_INTERVAL=0.40

# --- Chu kỳ cập nhật lái (giây) — tần suất đọc camera + điều chỉnh servo ---
# Thấp hơn = servo phản hồi nhanh hơn nhưng tốn CPU hơn
# 0.05 = 20Hz (mỗi vòng quay servo ~50ms), 0.08 = 12.5Hz
NAV_LINE_FOLLOW_INTERVAL=0.05
