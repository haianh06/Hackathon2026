#!/usr/bin/env python3
"""
Object Detection Service for Delivery Bot
==========================================

Skeleton service that:
  1. Connects to the MJPEG camera stream from the hardware daemon
  2. Connects to the Node.js backend via Socket.IO
  3. Provides start/stop/detect_once HTTP endpoints
  4. Runs a detection loop that grabs frames and runs detection

TODO (add your algorithm here):
  - Load your model in `_load_model()`
  - Implement detection in `_detect_frame(frame)` → list of dicts
  - Each detection dict: {"class": str, "confidence": float, "bbox": [x1,y1,x2,y2]}
"""

import asyncio
import logging
import os
import signal
import time

import aiohttp
from aiohttp import web
import cv2
import numpy as np
import socketio

# ── Config from environment ──
BACKEND_URL = os.environ.get('BACKEND_URL', 'http://backend:5000')
CAMERA_MJPEG_URL = os.environ.get('CAMERA_MJPEG_URL', 'http://hardware:8765/stream')
DETECT_PORT = int(os.environ.get('DETECT_PORT', '9002'))
DETECT_INTERVAL_MS = int(os.environ.get('DETECT_INTERVAL_MS', '500'))
CONF_THRESHOLD = float(os.environ.get('CONF_THRESHOLD', '0.5'))

logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s [%(name)s] %(levelname)s: %(message)s'
)
logger = logging.getLogger('detect-object')


class ObjectDetector:
    """
    Base object detector. Override `_load_model` and `_detect_frame`
    with your actual detection algorithm.
    """

    def __init__(self):
        self.model = None
        self.ready = False
        self._load_model()
	self.threshhold = 30
	self.target = None

    def _load_model(self):
        """
        TODO: Load your detection model here.

        Example (ONNX):
            import onnxruntime as ort
            self.session = ort.InferenceSession('model.onnx')

        Example (PyTorch):
            import torch
            self.model = torch.load('model.pt')
            self.model.eval()

        Example (TFLite):
            import tflite_runtime.interpreter as tflite
            self.interpreter = tflite.Interpreter(model_path='model.tflite')
            self.interpreter.allocate_tensors()
        """
        logger.info("ObjectDetector: no model loaded yet (skeleton mode)")
        logger.info("  → Add your model loading code in _load_model()")
        self.ready = True  # Set True so the loop runs; frames just return empty

    def detect(self, frame_bgr):
        """
        Run detection on a BGR OpenCV frame.
        Returns list of detections: [{"class": str, "confidence": float, "bbox": [x1,y1,x2,y2]}]
        """
        if frame_bgr is None:
            return []
        return self._detect_frame(frame_bgr)

    def _detect_frame(self, frame):
        """
        TODO: Implement your detection algorithm here.

        Input:  frame — OpenCV BGR image (numpy ndarray, shape HxWx3)
        Output: list of dicts, each with keys:
                  - "class": str — class name (e.g. "person", "car", "stop_sign")
                  - "confidence": float — 0.0 to 1.0
                  - "bbox": [x1, y1, x2, y2] — bounding box in pixels

        Example (placeholder):
            h, w = frame.shape[:2]
            return [{"class": "placeholder", "confidence": 0.99, "bbox": [10, 10, w-10, h-10]}]
        """
        # Skeleton: return empty list (no detections)
	h, w = frame.shape[:2]
	ROI = frame[]
	mean_ROI = np.mean(ROI)
	if abs(self.target - mean_ROI) < self.threshold:
	    return True
	else:
	    return False
        return []

class DetectionService:
    """
    Main service: HTTP API + Socket.IO client + MJPEG consumer + detection loop.
    """

    def __init__(self):
        self.detector = ObjectDetector()
        self.detecting = False
        self._detect_task = None
        self.sio = socketio.AsyncClient(reconnection=True, reconnection_delay=2)
        self._latest_frame = None
        self._frame_lock = asyncio.Lock()
        self._mjpeg_task = None

    # ── MJPEG stream consumer ──

    async def _consume_mjpeg(self):
        """Continuously read MJPEG stream and keep latest frame."""
        logger.info(f"MJPEG consumer: connecting to {CAMERA_MJPEG_URL}")
        while True:
            try:
                async with aiohttp.ClientSession() as session:
                    async with session.get(CAMERA_MJPEG_URL, timeout=aiohttp.ClientTimeout(total=0)) as resp:
                        boundary = None
                        content_type = resp.headers.get('Content-Type', '')
                        if 'boundary=' in content_type:
                            boundary = content_type.split('boundary=')[-1].strip()

                        buffer = b''
                        async for chunk in resp.content.iter_any():
                            buffer += chunk
                            # Find JPEG frames in buffer
                            while True:
                                start = buffer.find(b'\xff\xd8')
                                end = buffer.find(b'\xff\xd9', start + 2) if start >= 0 else -1
                                if start < 0 or end < 0:
                                    # Keep only from last potential start
                                    if start >= 0:
                                        buffer = buffer[start:]
                                    elif len(buffer) > 200000:
                                        buffer = buffer[-10000:]
                                    break
                                jpeg_data = buffer[start:end + 2]
                                buffer = buffer[end + 2:]
                                # Decode
                                nparr = np.frombuffer(jpeg_data, np.uint8)
                                frame = cv2.imdecode(nparr, cv2.IMREAD_COLOR)
                                if frame is not None:
                                    async with self._frame_lock:
                                        self._latest_frame = frame
            except asyncio.CancelledError:
                return
            except Exception as e:
                logger.warning(f"MJPEG consumer error: {e}")
                await asyncio.sleep(2)

    async def _get_frame(self):
        """Get latest camera frame."""
        async with self._frame_lock:
            return self._latest_frame

    # ── Detection loop ──

    async def _detection_loop(self):
        """Grab frames and run detection at configured interval."""
        logger.info(f"Detection loop started (interval={DETECT_INTERVAL_MS}ms)")
        interval = DETECT_INTERVAL_MS / 1000.0

        while self.detecting:
            loop_start = time.time()
            try:
                frame = await self._get_frame()
                if frame is not None:
                    detections = self.detector.detect(frame)
                    if self.sio.connected:
                        await self.sio.emit('object-detect-result', {
                            'detections': detections,
                            'timestamp': time.time(),
                        })
                    # Also emit to backend socket for forwarding
                    if detections:
                        logger.info(f"Detected {len(detections)} objects")
            except Exception as e:
                logger.error(f"Detection loop error: {e}")

            elapsed = time.time() - loop_start
            if elapsed < interval:
                await asyncio.sleep(interval - elapsed)

        logger.info("Detection loop stopped")

    async def _detect_once(self):
        """Single-frame detection."""
        frame = await self._get_frame()
        if frame is None:
            return {'detections': [], 'error': 'No camera frame available'}

        detections = self.detector.detect(frame)
        result = {'detections': detections, 'timestamp': time.time()}

        if self.sio.connected:
            await self.sio.emit('object-detect-result', result)

        return result

    def start_detecting(self):
        if self.detecting:
            return
        self.detecting = True
        self._detect_task = asyncio.ensure_future(self._detection_loop())
        if self.sio.connected:
            asyncio.ensure_future(self.sio.emit('object-detect-status', {'detecting': True}))
        logger.info("Detection started")

    def stop_detecting(self):
        self.detecting = False
        if self._detect_task:
            self._detect_task.cancel()
            self._detect_task = None
        if self.sio.connected:
            asyncio.ensure_future(self.sio.emit('object-detect-status', {'detecting': False}))
        logger.info("Detection stopped")

    # ── Socket.IO connection to backend ──

    async def connect_backend(self):
        """Connect to Node.js backend via Socket.IO."""
        @self.sio.event
        async def connect():
            logger.info(f"Connected to backend: {BACKEND_URL}")
            await self.sio.emit('join-room', 'detect-object')

        @self.sio.event
        async def disconnect():
            logger.warning("Disconnected from backend")

        # Listen for commands from frontend (via backend relay)
        @self.sio.on('object-detect-start-cmd')
        async def on_start(data=None):
            self.start_detecting()

        @self.sio.on('object-detect-stop-cmd')
        async def on_stop(data=None):
            self.stop_detecting()

        @self.sio.on('object-detect-once-cmd')
        async def on_once(data=None):
            await self._detect_once()

        try:
            await self.sio.connect(BACKEND_URL)
        except Exception as e:
            logger.error(f"Backend connection failed: {e}")

    # ── HTTP API ──

    async def handle_start(self, request):
        self.start_detecting()
        return web.json_response({'status': 'started'})

    async def handle_stop(self, request):
        self.stop_detecting()
        return web.json_response({'status': 'stopped'})

    async def handle_detect_once(self, request):
        result = await self._detect_once()
        return web.json_response(result)

    async def handle_health(self, request):
        return web.json_response({
            'status': 'ok',
            'detecting': self.detecting,
            'model_ready': self.detector.ready,
            'camera_connected': self._latest_frame is not None,
        })

    # ── Main entry ──

    async def run(self):
        """Start all services."""
        # Start MJPEG consumer
        self._mjpeg_task = asyncio.ensure_future(self._consume_mjpeg())

        # Connect to backend
        await self.connect_backend()

        # Start HTTP API
        app = web.Application()
        app.router.add_post('/start', self.handle_start)
        app.router.add_post('/stop', self.handle_stop)
        app.router.add_post('/detect_once', self.handle_detect_once)
        app.router.add_get('/health', self.handle_health)

        runner = web.AppRunner(app)
        await runner.setup()
        site = web.TCPSite(runner, '0.0.0.0', DETECT_PORT)
        await site.start()
        logger.info(f"HTTP API listening on port {DETECT_PORT}")

        # Keep running
        try:
            while True:
                await asyncio.sleep(3600)
        except asyncio.CancelledError:
            pass
        finally:
            self.stop_detecting()
            if self._mjpeg_task:
                self._mjpeg_task.cancel()
            await runner.cleanup()


def main():
    service = DetectionService()

    loop = asyncio.new_event_loop()
    asyncio.set_event_loop(loop)

    # Graceful shutdown
    for sig in (signal.SIGINT, signal.SIGTERM):
        loop.add_signal_handler(sig, lambda: loop.stop())

    try:
        loop.run_until_complete(service.run())
    except KeyboardInterrupt:
        pass
    finally:
        loop.close()


if __name__ == '__main__':
    main()
