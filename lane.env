# ═══════════════════════════════════════════════════════════════
# Lane Follower — Sliding Window BEV + Polynomial Regression
# Dùng cho MapPage (xe chạy tự động) và MapBuilder (build map)
# Chỉnh các giá trị dưới đây mà không cần rebuild Docker
# ═══════════════════════════════════════════════════════════════

# --- Kích thước khung hình xử lý (pixel) ---
LF_FRAME_WIDTH=640
LF_FRAME_HEIGHT=480

# ═══════════════════════════════════════════════════════════════
# Bird's Eye View (BEV) — Biến đổi phối cảnh
# 4 điểm nguồn trên frame gốc → 4 điểm đích trên ảnh BEV
# Tính theo % kích thước frame / BEV
# ═══════════════════════════════════════════════════════════════

# Kích thước ảnh BEV output (pixel)
LF_BEV_WIDTH=300
LF_BEV_HEIGHT=300

# 4 điểm nguồn (src) — hình thang trên frame gốc (% frame)
# Thứ tự: top-left, top-right, bottom-right, bottom-left
LF_BEV_SRC_TL_X=0.30
LF_BEV_SRC_TL_Y=0.50
LF_BEV_SRC_TR_X=0.70
LF_BEV_SRC_TR_Y=0.50
LF_BEV_SRC_BR_X=1.00
LF_BEV_SRC_BR_Y=0.95
LF_BEV_SRC_BL_X=0.00
LF_BEV_SRC_BL_Y=0.95

# 4 điểm đích (dst) — hình chữ nhật trên ảnh BEV (% BEV size)
LF_BEV_DST_TL_X=0.10
LF_BEV_DST_TL_Y=0.0
LF_BEV_DST_TR_X=0.90
LF_BEV_DST_TR_Y=0.0
LF_BEV_DST_BR_X=0.90
LF_BEV_DST_BR_Y=1.0
LF_BEV_DST_BL_X=0.10
LF_BEV_DST_BL_Y=1.0

# ═══════════════════════════════════════════════════════════════
# Lane Geometry — Hình học làn đường trên BEV (pixel)
# ═══════════════════════════════════════════════════════════════

# Độ rộng làn đường trên ảnh BEV (pixel)
LF_LANE_WIDTH_BEV=140
# Vị trí mong muốn của vạch phải trên ảnh BEV (pixel từ trái)
LF_TARGET_RIGHT_X_BEV=210

# ═══════════════════════════════════════════════════════════════
# Binary Mask — Threshold cho ảnh nhị phân
# ═══════════════════════════════════════════════════════════════

# Ngưỡng sáng để tách vạch trắng (0–255)
LF_BINARY_THRESHOLD=180
# Kích thước kernel GaussianBlur
LF_BLUR_KERNEL=5
# Kích thước kernel morphology (loại nhiễu)
LF_MORPH_KERNEL=3

# ═══════════════════════════════════════════════════════════════
# Sliding Window — Tham số cửa sổ trượt
# ═══════════════════════════════════════════════════════════════

# Số cửa sổ trượt từ dưới lên trên
LF_N_WINDOWS=9
# Biên rộng mỗi cửa sổ (pixel)
LF_WINDOW_MARGIN=40
# Số pixel tối thiểu để re-center cửa sổ
LF_MIN_PIX_RECENTER=30

# ═══════════════════════════════════════════════════════════════
# Polynomial / Targeted Search
# ═══════════════════════════════════════════════════════════════

# Biên tìm kiếm quanh polynomial cũ (pixel)
LF_SEARCH_MARGIN=50
# Số frame mất line liên tiếp trước khi bỏ polynomial lock
LF_LOCK_LOST_MAX=15

# ═══════════════════════════════════════════════════════════════
# PID Controller — Điều khiển bám làn
# u(t) = Kp*e(t) + Ki*∫e(τ)dτ + Kd*de(t)/dt
# ═══════════════════════════════════════════════════════════════

LF_PID_KP=0.85
LF_PID_KI=0.05
LF_PID_KD=0.60
# Anti-windup: giới hạn tích phân
LF_PID_INTEGRAL_MAX=2.0
# EMA alpha cho output PID (0=mượt max, 1=không lọc)
LF_STEER_EMA_ALPHA=0.3

# ═══════════════════════════════════════════════════════════════
# Kalman Filter — Lọc CTE loại nhiễu đột biến
# state = [cte, d_cte/dt]
# ═══════════════════════════════════════════════════════════════

# Process noise (nhỏ = tin mô hình, lớn = đáp ứng nhanh)
LF_KALMAN_Q=0.005
# Measurement noise khi detect tốt (tin cận — nhỏ)
LF_KALMAN_R_NORMAL=0.05
# Measurement noise khi detect kém (kém tin cận — lớn)
LF_KALMAN_R_DEGRADED=0.20
# Outlier gate: bác bỏ measurement nếu innovation > gate * sqrt(S)
LF_KALMAN_GATE=3.5

# ═══════════════════════════════════════════════════════════════
# Intersection Detection — Phát hiện đường ngang
# ═══════════════════════════════════════════════════════════════

# Ngưỡng % chiều rộng BEV để coi là có đường ngang
LF_HORIZ_LINE_THRESH=0.40

# ═══════════════════════════════════════════════════════════════
# Recovery — Dự đoán khi mất line
# ═══════════════════════════════════════════════════════════════

# Số frame tối đa dùng Kalman predict khi mất line
LF_MAX_PREDICT_FRAMES=20

# Vị trí đo CTE (% chiều cao BEV, 0=trên, 1=dưới)
LF_EVAL_Y_FRAC=0.85

# ═══════════════════════════════════════════════════════════════
# Odometry — Bicycle Kinematic Model + Sensor Fusion
# Xây dựng hệ toạ độ Oxy từ điểm xuất phát xe
# ═══════════════════════════════════════════════════════════════

# Chiều dài cơ sở xe (khoảng cách trục trước - trục sau, mét)
ODO_WHEELBASE=0.12
# Tốc độ ước lượng khi xe chạy thẳng (m/s)
ODO_SPEED_MPS=0.15
# Hệ số chuyển correction [-1,1] → góc lái (radian)
ODO_STEER_TO_ANGLE=0.45
# Trọng số vision CTE trong sensor fusion (0–1)
ODO_VISION_WEIGHT=0.70
# Trọng số odometry CTE (1 - vision_weight)
ODO_ODOM_WEIGHT=0.30
# Alpha hiệu chỉnh pose bằng vision (nhỏ = ít hiệu chỉnh)
ODO_CORRECTION_ALPHA=0.30
# Số entry tối đa trong history log
ODO_MAX_HISTORY=500
