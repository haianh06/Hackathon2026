# ═══════════════════════════════════════════════════════════════
# Canny Lane Detection — Cấu hình cho AdaptiveTrackerV2
# Dùng cho MapPage (xe chạy tự động) và MapBuilder (build map)
# Chỉnh các giá trị dưới đây mà không cần rebuild Docker
# ═══════════════════════════════════════════════════════════════

# --- Kích thước khung hình xử lý (pixel) ---
CANNY_FRAME_WIDTH=640
CANNY_FRAME_HEIGHT=480

# --- Camera X offset (pixel) ---
# Bù trừ nếu camera không gắn chính giữa xe
# Dương = camera lệch phải, âm = lệch trái
CANNY_CAMERA_X_OFFSET=0

# ═══════════════════════════════════════════════════════════════
# ROI (Region of Interest) — Vùng quét lane
# Tính theo phần trăm chiều cao/rộng frame (0.0 – 1.0)
# ═══════════════════════════════════════════════════════════════

# Cạnh dưới ROI (gần xe) — % chiều cao frame
CANNY_ROI_BOTTOM_FRAC=0.85
# Cạnh trên ROI (xa xe) — % chiều cao frame
CANNY_ROI_TOP_FRAC=0.60
# Số dòng quét trong ROI
CANNY_NUM_SCANS=12
# Độ rộng làn đường chuẩn — % chiều rộng frame
CANNY_STANDARD_LANE_WIDTH_FRAC=0.6

# ROI ban đầu (% chiều rộng frame)
# [left_bottom, right_bottom, left_top, right_top]
CANNY_ROI_INIT_LEFT_BOT=0.15
CANNY_ROI_INIT_RIGHT_BOT=0.85
CANNY_ROI_INIT_LEFT_TOP=0.30
CANNY_ROI_INIT_RIGHT_TOP=0.70
# Hệ số EMA để cập nhật ROI mượt (0=giữ cũ, 1=theo mới hoàn toàn)
CANNY_ROI_EMA_ALPHA=0.2

# ═══════════════════════════════════════════════════════════════
# TARGET FIX CỨNG — Hệ trục tọa độ lấy xe làm gốc (Ego-centric)
# Vị trí mong muốn của vạch trái và vạch phải trên frame (pixel)
# Nếu xe đang chạy giữa làn, 2 vạch trắng phải nằm đúng target
# ═══════════════════════════════════════════════════════════════

# Target X cho vạch trái tại đáy ROI (pixel từ cạnh trái frame)
CANNY_TARGET_LEFT_X=140
# Target X cho vạch phải tại đáy ROI (pixel từ cạnh trái frame)
CANNY_TARGET_RIGHT_X=500
# Target center lane = trung điểm 2 target, = (140+500)/2 = 320 = giữa frame

# Dòng quét Target X (% chiều cao frame, 0.0=trên cùng, 1.0=dưới cùng)
# Đẩy trọng tâm quét lên cao hơn baseline để khi xe bị lệch vẫn thấy vạch
# 0.70 = quét ở 70% chiều cao (cao hơn baseline 0.85)
CANNY_TARGET_X_SCAN_Y_FRAC=0.70

# ═══════════════════════════════════════════════════════════════
# PID Controller — Điều khiển bám làn bằng Cross-Track Error
# u(t) = Kp*e(t) + Ki*∫e(τ)dτ + Kd*de(t)/dt
# e(t) = CTE = (actual_center - target_center) / (frame_width/2)
# ═══════════════════════════════════════════════════════════════

CANNY_PID_KP=0.85
CANNY_PID_KI=0.05
CANNY_PID_KD=0.60
# Anti-windup: giới hạn tích phân
CANNY_PID_INTEGRAL_MAX=2.0
# EMA alpha cho output PID (0=mượt max, 1=không lọc)
CANNY_PID_STEER_EMA_ALPHA=0.3

# ═══════════════════════════════════════════════════════════════
# Pure Pursuit — Lookahead cho đường cong
# Thay vì fix cứng 1 điểm, Pure Pursuit lấy điểm nhìn xa (lookahead)
# dọc theo đường cong, giúp ôm cua mượt hơn PID thuần túy
# ═══════════════════════════════════════════════════════════════

# Khoảng cách lookahead tối thiểu (pixel trên frame)
CANNY_PURSUIT_LOOKAHEAD_MIN=60
# Khoảng cách lookahead tối đa (pixel trên frame)
CANNY_PURSUIT_LOOKAHEAD_MAX=180
# Gain cho Pure Pursuit (cao = bám sát, thấp = mượt)
CANNY_PURSUIT_GAIN=1.2

# ═══════════════════════════════════════════════════════════════
# Bird's Eye View (BEV) — Biến đổi phối cảnh
# 4 điểm nguồn trên frame gốc → 4 điểm đích trên ảnh BEV
# Tính theo % kích thước frame
# ═══════════════════════════════════════════════════════════════

# Kích thước ảnh BEV output (pixel)
CANNY_BEV_WIDTH=200
CANNY_BEV_HEIGHT=200

# 4 điểm nguồn (src) — hình thang trên frame gốc (% frame)
# Thứ tự: top-left, top-right, bottom-right, bottom-left
# Đáy rộng (gần xe), đỉnh hẹp (xa xe) để tạo góc nhìn thẳng từ trên xuống
CANNY_BEV_SRC_TL_X=0.30
CANNY_BEV_SRC_TL_Y=0.50
CANNY_BEV_SRC_TR_X=0.70
CANNY_BEV_SRC_TR_Y=0.50
CANNY_BEV_SRC_BR_X=1.00
CANNY_BEV_SRC_BR_Y=0.95
CANNY_BEV_SRC_BL_X=0.00
CANNY_BEV_SRC_BL_Y=0.95

# 4 điểm đích (dst) — hình chữ nhật trên ảnh BEV (% BEV size)
CANNY_BEV_DST_TL_X=0.10
CANNY_BEV_DST_TL_Y=0.0
CANNY_BEV_DST_TR_X=0.90
CANNY_BEV_DST_TR_Y=0.0
CANNY_BEV_DST_BR_X=0.90
CANNY_BEV_DST_BR_Y=1.0
CANNY_BEV_DST_BL_X=0.10
CANNY_BEV_DST_BL_Y=1.0

# ═══════════════════════════════════════════════════════════════
# Drift Compensation (bù trôi cơ khí)
# ═══════════════════════════════════════════════════════════════

# Hằng số bù trôi sang phải (cộng vào steer output)
CANNY_DRIFT_COMPENSATION=0.04
# Boost Kp khi xe lệch trái (nhân Kp khi CTE < 0)
CANNY_LEFT_DRIFT_BOOST=1.25

# ═══════════════════════════════════════════════════════════════
# Intersection Detection (phát hiện ngã rẽ)
# ═══════════════════════════════════════════════════════════════

# Số frame liên tiếp phải detect được line ngang mới lock ROI
CANNY_INTERSECTION_CONFIRM_THRESHOLD=3
# Số frame cooldown sau khi unlock ROI
CANNY_INTERSECTION_COOLDOWN_FRAMES=15

# ═══════════════════════════════════════════════════════════════
# Binary Mask — Threshold cho ảnh nhị phân
# ═══════════════════════════════════════════════════════════════

# Ngưỡng sáng để tách vạch trắng (0–255)
CANNY_BINARY_THRESHOLD=180
# Kích thước kernel GaussianBlur
CANNY_BLUR_KERNEL=5
# Kích thước kernel morphology (loại nhiễu)
CANNY_MORPH_KERNEL=3
